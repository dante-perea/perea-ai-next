# ─── VAPI (required for AI qualification calls) ───────────────────────────────
# Get this from: https://dashboard.vapi.ai → Account → API Keys → Private Key
VAPI_PRIVATE_KEY=your_vapi_private_key_here

# ─── Optional: Slack webhook for call notifications ──────────────────────────
# Create at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ─── Clerk (authentication for /dashboard) ───────────────────────────────────
# Create a Clerk app at https://dashboard.clerk.com → Add application
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── Vercel Blob (data lake file storage) ────────────────────────────────────
# Create at: https://vercel.com/dashboard → Storage → Blob → Create store
# Then: vercel env pull .env.local  (or copy BLOB_READ_WRITE_TOKEN manually)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ─── MCP endpoint bearer token (optional) ────────────────────────────────────
# If set, GET /api/mcp/dashboard requires: Authorization: Bearer <value>
# Omit this var to leave the endpoint open (fine for private/local use)
MCP_SECRET=

# ─── /dante route password gate (required for /dante route) ─────────────────
# HTTP Basic Auth password. Browser shows a native prompt (any username works).
# Must be set in BOTH .env.local (for dev) and Vercel project env (for prod) —
# missing this var means /dante 401's everyone (fail-closed).
DANTE_PASSWORD=bBnNmM11!!

# ─── gbrain Supabase Postgres (required for /dante route) ────────────────────
# The /dante public page reads project pages from Dante's gbrain (Supabase
# project ref: oggrvlkupnljwyfvbnft). Vercel functions are IPv4-only on
# standard regions, so use the SESSION POOLER URL — NOT the direct
# db.<ref>.supabase.co URL, which is IPv6-only on the free tier.
#
# Get it from: Supabase dashboard → Settings → Database → Session pooler
# Format: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
GBRAIN_DATABASE_URL=postgresql://postgres.oggrvlkupnljwyfvbnft:[PASSWORD]@aws-0-<region>.pooler.supabase.com:6543/postgres

# ─── Ghost (Neon) experiments database (required for /dante updates timeline) ─
# Same DB used by /dashboard/experiments. The /dante route reads day-grouped
# counts only — never hypothesis or learning text.
GHOST_DATABASE_URL=postgresql://...
